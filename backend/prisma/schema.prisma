// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlserver"
  url      = env("DATABASE_URL")
}

// ─── Enums ─────────────────────────────────────────────────────────────────
// NOTE: Prisma SQL Server connector does not support Prisma `enum` types.
// We store these values as Strings in SQL Server (see fields below) and validate them in the app layer.









// ─── Models ────────────────────────────────────────────────────────────────

model User {
  id             String          @id @default(cuid())
  kekaId         String?         @unique
  name           String
  email          String          @unique
  passwordHash   String
  role           String        @default("EMPLOYEE")
  employmentType String  @default("FULLTIME")
  department     String?
  designation    String?
  managerId      String?
  avatarUrl      String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  // Relations
  manager           User? @relation("Manager", fields: [managerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reports           User[]            @relation("Manager")
  projectMembers    ProjectMember[]
  timesheetEntries  TimesheetEntry[]
  timesheetApprovals TimesheetApproval[]
  incidents         Incident[]
  notifications     Notification[]
  taskAssignments   Task[]            @relation("Assignee")

  @@map("users")
}

model Project {
  id          String        @id @default(cuid())
  name        String
  code        String        @unique
  description String?
  client      String?
  status      String @default("ACTIVE")
  billable    Boolean       @default(true)
  startDate   DateTime
  endDate     DateTime
  budgetHours Float         @default(0)
  managerId   String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Relations
  members          ProjectMember[]
  tasks            Task[]
  timesheetEntries TimesheetEntry[]

  @@map("projects")
}

model Employee {
  id               String   @id @default(cuid())
  employeeNumber   String   @unique
  firstName        String
  middleName       String?  // optional
  lastName         String
  email            String   @unique
  dateOfBirth      DateTime
  gender           String
  dateOfJoining    DateTime

  @@map("employees")
}

model ProjectMember {
  id             String   @id @default(cuid())
  projectId      String
  userId         String
  allocation     Float    @default(100) // percentage - 100 = fulltime on project
  role           String?  // Project role e.g. "Lead Developer"
  startDate      DateTime?
  endDate        DateTime?
  createdAt      DateTime @default(now())

  project        Project @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  user           User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([projectId, userId])
  @@map("project_members")
}

model Task {
  id             String     @id @default(cuid())
  projectId      String
  title          String
  description    String?
  type           String   @default("TASK")
  milestone      String?    // milestone group name
  assigneeId     String?
  startDate      DateTime?
  endDate        DateTime?
  estimatedHours Float      @default(0)
  status         String @default("NOT_STARTED")
  sortOrder      Int        @default(0)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  project        Project @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  assignee       User? @relation("Assignee", fields: [assigneeId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  timesheetEntries TimesheetEntry[]

  @@map("tasks")
}

model TimesheetEntry {
  id          String          @id @default(cuid())
  userId      String
  projectId   String
  taskId      String?
  date        DateTime        @db.Date
  hours       Float
  description String?
  billable    Boolean         @default(true)
  status      String @default("DRAFT")
  weekStart   DateTime        @db.Date  // Monday of the week
  overriddenBy String?        // PM override user id
  overrideNote String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  user         User    @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project      Project @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task         Task?   @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approvals TimesheetApproval[]

  @@map("timesheet_entries")
}

model TimesheetApproval {
  id          String          @id @default(cuid())
  entryId     String
  approverId  String
  action      String // APPROVED or REJECTED
  note        String?
  createdAt   DateTime        @default(now())

  entry       TimesheetEntry @relation(fields: [entryId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver    User           @relation(fields: [approverId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("timesheet_approvals")
}

model Incident {
  id           String       @id @default(cuid())
  userId       String
  type         String
  weekStart    DateTime     @db.Date
  description  String?
  chaseCount   Int          @default(0)
  lastChasedAt DateTime?
  resolved     Boolean      @default(false)
  resolvedAt   DateTime?
  resolvedNote String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("incidents")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String
  channel   String
  subject   String
  body      String
  read      Boolean             @default(false)
  sentAt    DateTime?
  createdAt DateTime            @default(now())

  user      User @relation(fields: [userId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("notifications")
}

model KekaSyncLog {
  id          String   @id @default(cuid())
  syncedAt    DateTime @default(now())
  recordsSync Int      @default(0)
  status      String   // SUCCESS, FAILED
  error       String?

  @@map("keka_sync_logs")
}
 